{
  "rust-analyzer.check.command": "clippy",
  "rust-analyzer.check.extraArgs": ["--all-targets", "--all-features"],
  "editor.formatOnSave": true,
  "editor.rulers": [100],
  "files.exclude": {
    "target/": true,
    "**/*.swp": true
  },
  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer"
  }
}
